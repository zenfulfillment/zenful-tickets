# Copy to .env.build (gitignored) and fill in.
# Loaded by scripts/build.sh before `tauri build`.

# ElevenLabs Scribe V2 Realtime — baked into the binary via `option_env!`
# in src-tauri/src/speech.rs. If unset, voice capture is disabled.
ELEVENLABS_API_KEY=

# Tauri updater signing key — generated via:
#   pnpm tauri signer generate -w ~/.tauri/zenfultickets.key
# Paste the contents of that file (a single base64 line) below.
# The matching public key lives in src-tauri/tauri.conf.json under plugins.updater.pubkey.
TAURI_SIGNING_PRIVATE_KEY=
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=
